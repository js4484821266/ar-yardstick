<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ARCore SceneView will be added programmatically -->
    <FrameLayout
        android:id="@+id/arFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top control panel -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#CC000000"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/modeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mode_arbitrary"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/switchModeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/switch_mode"
            android:textSize="14sp" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clear"
            android:layout_marginStart="8dp"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Instruction text -->
    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/topPanel"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="@string/arbitrary_mode_instructions"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:background="#AA000000"
        android:padding="8dp" />

    <!-- Measurement display with high contrast and 12pt font -->
    <TextView
        android:id="@+id/measurementText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:textColor="#FFFFFF"
        android:textSize="12pt"
        android:textStyle="bold"
        android:background="#FF000000"
        android:padding="12dp"
        android:visibility="gone"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4" />

</RelativeLayout>
